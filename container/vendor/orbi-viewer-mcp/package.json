{
  "name": "orbi-mcp",
  "version": "1.0.0",
  "description": "MCP Server for orbi.kr - Korea's largest entrance exam community",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "orbi-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
